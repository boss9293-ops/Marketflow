{
  "version": "validation_guard_policy_v1",
  "windows": {
    "baseline": {
      "start": "2017-01-01",
      "end": "2019-12-31"
    },
    "crisis_2020": {
      "start": "2020-01-01",
      "end": "2020-06-30"
    },
    "crisis_2022": {
      "start": "2022-01-01",
      "end": "2022-12-31"
    }
  },
  "thresholds": {
    "false_alarm_rate_max_delta": 0.05,
    "coverage_min_delta": -0.07,
    "stability_mps_abschg95_max_delta": 8.0,
    "avg_confidence_min": 60.0
  },
  "revision_detection": {
    "lookback_days": 60,
    "change_epsilon": 1e-06
  },
  "schedule": {
    "daily_run_time_local": "18:30"
  },
  "badge_rules": {
    "ok_if": "all_pass",
    "watch_if": "any_fail_or_revision_detected"
  }
}
