{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "../../tmp/vr_run"
  },
  "include": [
    "../../vr/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
