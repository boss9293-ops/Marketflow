{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "./tmp/vr_out"
  },
  "include": [
    "vr/**/*.ts",
    "engine/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "marketflow"
  ]
}
