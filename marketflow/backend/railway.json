{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt",
    "watchPatterns": ["marketflow/backend/**"]
  },
  "deploy": {
    "startCommand": "gunicorn --bind :$PORT --workers 1 --threads 8 --timeout 0 app:app",
    "restartPolicyType": "ON_FAILURE"
  }
}
